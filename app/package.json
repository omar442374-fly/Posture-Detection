{
  "name": "posture-detection",
  "version": "1.0.0",
  "description": "Posture Detection Desktop App for Tech Workers",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "package": "electron-builder --win"
  },
  "keywords": ["posture", "health", "desktop", "electron"],
  "author": "Posture Detection",
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.7.0",
    "vite": "^5.3.4"
  },
  "build": {
    "appId": "com.posturedetection.app",
    "productName": "Posture Detection",
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../model",
        "to": "model",
        "filter": ["**/*", "!venv/**", "!__pycache__/**", "!*.pyc"]
      }
    ]
  }
}
